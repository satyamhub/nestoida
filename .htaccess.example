Options -Indexes

# Gmail SMTP configuration for verification/reset emails.
SetEnv SMTP_HOST smtp.gmail.com
SetEnv SMTP_PORT 587
SetEnv SMTP_SECURE tls
SetEnv SMTP_USER your_gmail@gmail.com
SetEnv SMTP_PASS your_gmail_app_password
SetEnv SMTP_FROM_EMAIL your_gmail@gmail.com
SetEnv SMTP_FROM_NAME Nestoida

# Google OAuth
SetEnv GOOGLE_CLIENT_ID your_google_client_id
SetEnv GOOGLE_CLIENT_SECRET your_google_client_secret
SetEnv GOOGLE_REDIRECT_URI https://your-domain.com/google-callback.php

# Tokens
SetEnv VERIFICATION_TOKEN_TTL_SECONDS 86400

# Base URL used to build verification/reset links.
SetEnv APP_URL https://your-domain.com

# Database
SetEnv DB_HOST localhost
SetEnv DB_USER nestoida_user
SetEnv DB_PASS your_db_password
SetEnv DB_NAME nestoida
